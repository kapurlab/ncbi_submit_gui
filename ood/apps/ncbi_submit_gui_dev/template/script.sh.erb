#!/usr/bin/env bash
# NCBI Submit GUI (dev) OOD batch_connect script.
# $port (uvicorn) and $worktree_dir are exported by before.sh.erb.

echo "=== NCBI Submit GUI (dev) Session Starting ==="
echo "uvicorn:${port}"
echo "worktree:${worktree_dir}"

SHARED_ENV=/srv/kapurlab/tools/ncbi_submit_gui/env
PERSONAL_ENV=/home/${USER}/miniforge3/envs/ncbi_submit
PERSONAL_BASE_PYTHON=/home/${USER}/miniforge3/bin/python

if [ -d "${SHARED_ENV}" ] && [ -x "${SHARED_ENV}/bin/python" ]; then
  ENV_DIR="${SHARED_ENV}"; PYTHON="${SHARED_ENV}/bin/python"
elif [ -d "${PERSONAL_ENV}" ]; then
  ENV_DIR="${PERSONAL_ENV}"; PYTHON="${PERSONAL_ENV}/bin/python"
else
  ENV_DIR=""; PYTHON="${PERSONAL_BASE_PYTHON}"
fi

SHARED_GUI=/srv/kapurlab/tools/ncbi_submit_gui
if [ -n "${worktree_dir}" ] && [ -d "${worktree_dir}/backend" ]; then
  GUI="${worktree_dir}"
else
  GUI="${SHARED_GUI}"
fi

export PATH="${ENV_DIR}/bin:${PATH}"
export PYTHONPATH="${GUI}/bin:${PYTHONPATH}"

# Dev: rebuild the frontend from the branch source so UI changes are served.
if [ -n "${worktree_dir}" ] && [ "${GUI}" = "${worktree_dir}" ] && [ -d "${GUI}/frontend" ]; then
  if [ ! -e "${GUI}/frontend/node_modules" ] && [ -d "${SHARED_GUI}/frontend/node_modules" ]; then
    ln -s "${SHARED_GUI}/frontend/node_modules" "${GUI}/frontend/node_modules"
  fi
  echo "Building frontend (vite) from worktree source…"
  ( cd "${GUI}/frontend" && npm run build ) \
    || echo "WARN: frontend build failed; serving existing dist/ if present."
fi

cd "${GUI}/backend"
echo "Starting uvicorn on port ${port}"
echo "  conda env: ${ENV_DIR}"
echo "  gui:       ${GUI}"
exec $PYTHON -m uvicorn app.main:app \
    --host 0.0.0.0 \
    --port "${port}" \
    --log-level info \
    --reload \
    --reload-dir app
