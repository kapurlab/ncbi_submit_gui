#!/usr/bin/env bash
# NCBI Submit GUI OOD batch_connect script.
# $port (uvicorn) is exported by before.sh.

echo "=== NCBI Submit GUI Session Starting ==="
echo "uvicorn:${port}"

# Shared conda env installed at the tool root; falls back to a personal install.
SHARED_ENV=/srv/kapurlab/tools/ncbi_submit_gui/env
PERSONAL_ENV=/home/${USER}/miniforge3/envs/ncbi_submit
PERSONAL_BASE_PYTHON=/home/${USER}/miniforge3/bin/python

if [ -d "${SHARED_ENV}" ] && [ -x "${SHARED_ENV}/bin/python" ]; then
  ENV_DIR="${SHARED_ENV}"; PYTHON="${SHARED_ENV}/bin/python"
elif [ -d "${PERSONAL_ENV}" ]; then
  ENV_DIR="${PERSONAL_ENV}"; PYTHON="${PERSONAL_ENV}/bin/python"
else
  ENV_DIR=""; PYTHON="${PERSONAL_BASE_PYTHON}"
fi

GUI=/srv/kapurlab/tools/ncbi_submit_gui

# Put the conda env bin on PATH so seqkit / table2asn resolve, and add bin/ to
# PYTHONPATH so the pipeline modules import each other.
export PATH="${ENV_DIR}/bin:${PATH}"
export PYTHONPATH="${GUI}/bin:${PYTHONPATH}"

# NCBI credentials are NOT exported here — the backend reads them from the
# user's private config (~/.config/ncbi_submit_gui/config.json) and injects
# them into the pipeline subprocess at run time, so they never touch session
# state or the dashboard.

cd "${GUI}/backend"
echo "Starting uvicorn on port ${port}"
echo "  conda env: ${ENV_DIR}"
echo "  gui:       ${GUI}"
exec $PYTHON -m uvicorn app.main:app \
    --host 0.0.0.0 \
    --port "${port}" \
    --log-level info
